---
const specialties = [
  "Automotive Salvage Buyers",
  "Premium Car Repairers",
  "Body & Colour Works",
  "Insurance Claim Support",
];

const links = [
  { name: "Home", href: "#home" },
  { name: "Services", href: "#services" },
  { name: "Process", href: "#process" },
  { name: "About", href: "#about" },
  { name: "Contact", href: "#contact" },
];
---

<section class="sm:px-5">
  <div class="w-full max-w-[1240px] mx-auto">
    <div
      class="px-6 bg-dark text-gray py-[55px] lg:px-[60px] sm:rounded-t-[45px]"
    >
      <div class="grid gap-10 lg:grid-cols-4">
        <div class="lg:col-span-1">
          <div class="flex items-center gap-3 mb-5">
            <span
              class="flex h-9 w-9 items-center justify-center rounded-full bg-green text-dark font-medium"
              >R</span
            >
            <span class="text-xl font-medium text-white">Royal Auto Garage</span>
          </div>
          <p class="text-sm leading-6">
            Royal Auto Garage is committed to providing world-class automotive
            excellence with a customer-first approach. We treat every car like
            royalty.
          </p>
        </div>

        <div>
          <h3 class="greenhead w-fit mb-5 text-lg font-medium">Our Specialties</h3>
          <ul class="flex flex-col gap-3 text-sm">
            {specialties.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div>
          <h3 class="greenhead w-fit mb-5 text-lg font-medium">Quick Navigation</h3>
          <ul class="flex flex-col gap-3 text-sm">
            {
              links.map((link) => (
                <li>
                  <a class="hover:text-green" href={link.href}>
                    {link.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3 class="greenhead w-fit mb-5 text-lg font-medium">Get In Touch</h3>
          <div class="flex flex-col gap-3 text-sm">
            <a class="hover:text-green" href="tel:+918758807860">+91 8758807860</a>
            <a class="hover:text-green" href="tel:+919909611091">+91 9909611091</a>
            <a class="hover:text-green" href="mailto:royalpathanfiroz@gmail.com"
              >royalpathanfiroz@gmail.com</a
            >
            <span>
              Shed No. 88, Karelibaug Ind. Estate, Baroda - 390 018. (Gujarat)
            </span>
          </div>
        </div>
      </div>

      <div class="h-[1px] bg-gray my-8"></div>
      <div
        class="flex flex-col lg:flex-row justify-center text-center gap-2 md:justify-between"
      >
        <span>© 2026 Royal Auto Garage. Developed by Royal Tech</span>
        <span class="flex gap-5 justify-center">
          <a class="underline" href="#">Privacy Policy</a>
          <a class="underline" href="#">Terms of Service</a>
        </span>
      </div>
    </div>
  </div>
</section>
