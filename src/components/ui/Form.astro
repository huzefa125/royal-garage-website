---
---

<div class="flex justify-start items-center p-8 sm:p-[60px] bg-[#F3F3F3] rounded-[45px]">
  <form class="w-full" action="#" method="post">
    <div class="mb-4">
      <label for="name" class="block text-black mb-2">Name</label>
      <input
        type="text"
        id="name"
        name="name"
        placeholder="Enter your name"
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none bg-white"
      />
    </div>

    <div class="mb-4">
      <label for="phone" class="block text-black mb-2">Phone</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        placeholder="Phone number"
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none bg-white"
      />
    </div>

    <div class="mb-4">
      <label for="email" class="block text-black mb-2">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="example@mail.com"
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none bg-white"
      />
    </div>

    <div class="mb-6">
      <label for="message" class="block text-black mb-2">Message</label>
      <textarea
        id="message"
        name="message"
        rows="4"
        placeholder="Tell us about your vehicle issues..."
        class="w-full px-[30px] py-[18px] border border-black rounded-[14px] text-black outline-none bg-white"
      ></textarea>
    </div>

    <button type="submit" name="submit" class="btn-primary w-full">Send Message</button>
  </form>
</div>
