---
import SectionTitle from "../ui/SectionTitle.astro";
import Section from "./Section.astro";

const cards = [
  {
    title: "Full Car Diagnostics",
    description:
      "Advanced diagnostic scanning to accurately identify and resolve all vehicle issues.",
    variant: "bg-gray",
  },
  {
    title: "Brake & Transmission",
    description:
      "Expert repair and maintenance to ensure safety, smooth performance, and reliability.",
    variant: "bg-green",
  },
  {
    title: "Painting, Denting & Accident Repair",
    description:
      "Complete bodywork solutions to restore your car's look and structural integrity.",
    variant: "bg-dark text-gray",
  },
  {
    title: "All Other Mechanical Work",
    description:
      "Comprehensive mechanical services covering engines, suspension, AC, and more.",
    variant: "bg-gray",
  },
];

const description =
  "We give your car premium treatment with state-of-the-art technology and skilled technicians.";
---

<Section id="services">
  <div class="mt-[140px] mb-5">
    <SectionTitle sectionTitle="Our Expert Services" description={description} />
    <div class="grid lg:grid-cols-2 gap-10">
      {
        cards.map((card) => (
          <div class="rounded-[45px] border border-dark shadow-[0px_5px_0px_#191a23]">
            <div class={`flex flex-col gap-5 p-8 sm:p-[50px] rounded-[45px] h-full ${card.variant}`}>
              <h3 class="text-2xl sm:text-3xl font-medium">{card.title}</h3>
              <p class="text-base">{card.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Section>
