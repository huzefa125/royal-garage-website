---
import Accordion from "../ui/Accordion.astro";
import SectionTitle from "../ui/SectionTitle.astro";
import Section from "./Section.astro";
import faqs from "../../data/faqData.json";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.answer,
    },
  })),
};
---

<Section id="faq">
  <div class="mt-[140px]">
    <SectionTitle
      sectionTitle="Frequently Asked Questions"
      description="Have a question in mind? We have compiled answers to the most common queries here."
    />
    <Accordion />
  </div>
</Section>

<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
