---
import Section from "./Section.astro";
---

<Section id="home">
  <div class="relative flex flex-col-reverse items-center md:flex-row" id="hero">
    <div class="row items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
      <div class="text-left space-y-3">
        <span
          class="greenhead inline-block text-sm font-medium uppercase tracking-wide"
          >Premium Car Care Center</span
        >
        <h1
          class="text-4xl font-medium leading-none md:text-6xl text-center md:text-left"
        >
          Expert Care for <br /> Your Luxury <br /> Vehicle
        </h1>
        <p
          class="mt-6 mb-8 text-lg font-normal leading-7 sm:mb-12 text-center md:text-left md:pr-12"
        >
          Experience world-class automotive excellence with certified experts,
          genuine parts, and the royal treatment your car deserves.
        </p>
        <div
          class="w-full justify-center md:justify-start items-center inline-flex"
        >
          <a
            href="#contact"
            class="px-8 py-5 bg-zinc-900 hover:bg-green rounded-2xl text-center text-white hover:text-black border text-xl font-normal leading-7"
            >Book Appointment</a
          >
        </div>
      </div>
    </div>
    <div class="flex items-center py-5 md:w-6/12 md:pb-16 md:pt-10">
      <div class="relative mx-auto w-full max-w-[560px] px-2 pb-6">
        <!-- soft green glow behind the image -->
        <div
          class="absolute inset-6 z-0 rounded-[2.5rem] bg-green/40 blur-2xl"
          aria-hidden="true"
        >
        </div>

        <!-- main image card -->
        <div
          class="relative z-10 overflow-hidden rounded-[2rem] shadow-[0_25px_60px_-15px_rgba(0,0,0,0.35)] ring-1 ring-black/5"
        >
          <img
            src="/cars/rangerover.webp"
            alt="Expert care for your luxury vehicle"
            width="640"
            height="520"
            loading="eager"
            class="h-full w-full object-cover"
          />
          <!-- bottom gradient for depth -->
          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-black/40 to-transparent"
            aria-hidden="true"
          >
          </div>
        </div>

        <!-- rating chip top-right -->
        <div
          class="absolute right-5 top-5 z-20 flex items-center gap-1.5 rounded-full bg-white/90 px-3.5 py-2 shadow-lg backdrop-blur"
        >
          <svg class="h-4 w-4 text-green" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.401 8.168L12 18.896l-7.335 3.866 1.401-8.168L.132 9.21l8.2-1.192z"></path>
          </svg>
          <span class="text-sm font-medium text-black">4.9 Rating</span>
        </div>

        <!-- floating stats badge bottom-left -->
        <div
          class="absolute -bottom-1 left-1 z-20 flex items-center gap-3 rounded-2xl bg-white px-5 py-3.5 shadow-[0_15px_35px_-10px_rgba(0,0,0,0.3)]"
        >
          <span class="flex h-11 w-11 items-center justify-center rounded-full bg-green">
            <svg class="h-6 w-6 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 6L9 17l-5-5"></path>
            </svg>
          </span>
          <div class="leading-tight">
            <p class="text-xl font-medium text-black">5000+</p>
            <p class="text-sm text-zinc-600">Cars Serviced</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Section>
